<!-- Add Event Modal -->
<div class="modal fade" id="addEventModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body p-4">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <input type="date" class="form-control" id="newEventDate">
                    </div>
                    <div class="col-6">
                        <input type="time" class="form-control" id="newEventTime">
                    </div>
                </div>
                <div class="mb-2">
                    <input type="text" class="form-control" id="newEventSubject" placeholder="Название">
                </div>
                <div class="mb-2">
                    <textarea class="form-control" rows="5" id="newEventDescription" placeholder="Описание"></textarea>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="button" class="btn btn-secondary flex-grow-1" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary flex-grow-1" onclick="saveNewEvent()">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
</div>