<!-- Tab 2: События -->
<div class="tab-pane fade" id="events-tab-pane" role="tabpanel" aria-labelledby="events-tab">
    <div class="card">
        <div class="card-body p-0">
            <!-- Controls at top -->
            <div id="eventsControls" class="p-2 border-bottom d-flex justify-content-between align-items-center" style="background-color: #f8f9fa;">
                <div class="d-flex gap-3">
                    <!-- Past events toggle -->
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="pastEventsToggle" onchange="togglePastEvents()">
                        <label class="form-check-label text-muted small" for="pastEventsToggle">Past <span id="pastCount" class="text-muted" style="display: none; font-size: 0.75rem;"></span></label>
                    </div>
                    <!-- Future events toggle -->
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="futureEventsToggle" onchange="toggleFutureEvents()">
                        <label class="form-check-label text-muted small" for="futureEventsToggle">Future</label>
                    </div>
                </div>
                <button class="btn btn-outline-primary btn-sm rounded-circle" style="width: 32px; height: 32px; padding: 0; line-height: 1;" onclick="showAddEventDialog()">+</button>
            </div>
            <div id="eventsList" class="list-group list-group-flush">
                <div class="text-center text-muted py-4">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    Загрузка событий...
                </div>
            </div>
        </div>
        
        <!-- Add Event Modal -->
        <div class="modal fade" id="addEventModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-body p-4">
                        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <input type="date" class="form-control" id="newEventDate">
                            </div>
                            <div class="col-6">
                                <input type="time" class="form-control" id="newEventTime">
                            </div>
                        </div>
                        <div class="mb-2">
                            <input type="text" class="form-control" id="newEventSubject" placeholder="Название">
                        </div>
                        <div class="mb-2">
                            <textarea class="form-control" rows="5" id="newEventDescription" placeholder="Описание"></textarea>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <button type="button" class="btn btn-secondary flex-grow-1" data-bs-dismiss="modal">Отмена</button>
                            <button type="button" class="btn btn-primary flex-grow-1" onclick="saveNewEvent()">Сохранить</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>