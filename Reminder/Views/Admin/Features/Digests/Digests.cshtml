<!-- Send Digests -->
<div class="col-12">
    <div class="card border-0 shadow-sm">
        <div class="card-body d-grid gap-2">
            <button type="button" class="btn btn-lg btn-outline-primary digest-btn" data-action="@Url.Action("Today", "Api")">
                Отправить на сегодня
            </button>
            <button type="button" class="btn btn-lg btn-outline-primary digest-btn" data-action="@Url.Action("Week", "Api")">
                Отправить на неделю
            </button>
            <button type="button" class="btn btn-lg btn-outline-primary digest-btn" data-action="@Url.Action("TwoWeek", "Api")">
                Отправить на две недели
            </button>
        </div>
    </div>
</div>

<script src="~/js/admin/features/digests/digests.js"></script>