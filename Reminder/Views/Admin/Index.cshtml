@{
    ViewData["Title"] = "Админка";
}

<link rel="stylesheet" href="~/css/admin.css" />

<ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="events-tab" data-bs-toggle="tab" data-bs-target="#events-tab-pane" type="button" role="tab" data-tab="events">
            📅 Events
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tools-tab" data-bs-toggle="tab" data-bs-target="#tools-tab-pane" type="button" role="tab" data-tab="tools" style="font-weight: 600;">
            ...
        </button>
    </li>
</ul>

<div class="tab-content" id="adminTabsContent">
    <!-- Tab 1: Events -->
    @await Html.PartialAsync("Features/Events/Events")

    <!-- Tab 2: Tools (Workouts, Shopping, Digests) -->
    <div class="tab-pane fade" id="tools-tab-pane" role="tabpanel" aria-labelledby="tools-tab">
        <!-- Nested tabs for tools -->
        <ul class="nav nav-pills mb-3" id="toolsTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="workouts-tab" data-bs-toggle="tab" data-bs-target="#workouts-tab-pane" type="button" role="tab">
                    🏃 Тренировки
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="shopping-tab" data-bs-toggle="tab" data-bs-target="#shopping-tab-pane" type="button" role="tab">
                    🛒 Покупки
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="digests-tab" data-bs-toggle="tab" data-bs-target="#digests-tab-pane" type="button" role="tab">
                    📬 Рассылка
                </button>
            </li>
        </ul>

        <div class="tab-content" id="toolsTabsContent">
            <div class="tab-pane fade show active" id="workouts-tab-pane" role="tabpanel">
                @await Html.PartialAsync("Features/Workouts/Workouts")
            </div>
            <div class="tab-pane fade" id="shopping-tab-pane" role="tabpanel">
                @await Html.PartialAsync("Features/Shopping/Shopping")
            </div>
            <div class="tab-pane fade" id="digests-tab-pane" role="tabpanel">
                @await Html.PartialAsync("Features/Digests/Digests")
            </div>
        </div>

        <div class="mt-3 text-end">
            <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-secondary">Выйти</a>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // API URLs
    window.apiUrls = {
        events: {
            getEvents: '@Url.Action("GetEvents", "Api")',
            addEvent: '@Url.Action("AddEvent", "Api")',
            updateEvent: '@Url.Action("UpdateEvent", "Api")',
            deleteEvent: '@Url.Action("DeleteEvent", "Api")'
        },
        workouts: {
            parseWorkouts: '@Url.Action("ParseWorkouts", "Api")',
            addWorkouts: '@Url.Action("AddWorkouts", "Api")'
        },
        shopping: {
            addShoppingItem: '@Url.Action("AddShoppingItem", "Api")',
            deleteShoppingItem: '@Url.Action("DeleteShoppingItem", "Api")'
        }
    };
</script>
<script src="~/js/admin/shared/shared.js"></script>
<script src="~/js/admin/features/events/events.js"></script>
<script src="~/js/admin/features/workouts/workouts.js"></script>
<script src="~/js/admin/features/shopping/shopping.js"></script>
<script src="~/js/admin/features/digests/digests.js"></script>
<script>
var eventsLoaded = false;

// Restore tab from URL hash
function restoreTabFromUrl() {
    var hash = window.location.hash.replace('#', '');
    if (hash === 'events') {
        switchToTab('events');
        if (!eventsLoaded) {
            loadEvents();
            eventsLoaded = true;
        }
    } else if (hash === 'tools' || hash === 'workouts' || hash === 'shopping' || hash === 'digests') {
        switchToTab('tools');
        
        // Handle nested tabs
        if (hash === 'workouts') {
            switchToNestedTab('workouts');
        } else if (hash === 'shopping') {
            switchToNestedTab('shopping');
        } else if (hash === 'digests') {
            switchToNestedTab('digests');
        }
    }
}

function switchToTab(tabName) {
    // Remove active from all tabs
    document.querySelectorAll('#adminTabs .nav-link').forEach(function(tab) {
        tab.classList.remove('active');
    });
    document.querySelectorAll('#adminTabsContent .tab-pane').forEach(function(pane) {
        pane.classList.remove('show', 'active');
    });
    
    // Activate selected tab
    var tab = document.getElementById(tabName + '-tab');
    var pane = document.getElementById(tabName + '-tab-pane');
    if (tab) tab.classList.add('active');
    if (pane) pane.classList.add('show', 'active');
}

function switchToNestedTab(tabName) {
    // Remove active from nested tabs
    document.querySelectorAll('#toolsTabs .nav-link').forEach(function(tab) {
        tab.classList.remove('active');
    });
    document.querySelectorAll('#toolsTabsContent .tab-pane').forEach(function(pane) {
        pane.classList.remove('show', 'active');
    });
    
    // Activate selected nested tab
    var tab = document.getElementById(tabName + '-tab');
    var pane = document.getElementById(tabName + '-tab-pane');
    if (tab) tab.classList.add('active', 'show');
    if (pane) pane.classList.add('show', 'active');
}

// Restore tab on page load
restoreTabFromUrl();

// Events tab
document.getElementById('events-tab').addEventListener('shown.bs.tab', function() {
    if (!eventsLoaded) {
        loadEvents();
        eventsLoaded = true;
    }
    window.location.hash = 'events';
});

// Tools tab
document.getElementById('tools-tab').addEventListener('shown.bs.tab', function() {
    window.location.hash = 'tools';
});

// Nested tabs
document.getElementById('workouts-tab').addEventListener('shown.bs.tab', function() {
    window.location.hash = 'workouts';
});

document.getElementById('shopping-tab').addEventListener('shown.bs.tab', function() {
    window.location.hash = 'shopping';
});

document.getElementById('digests-tab').addEventListener('shown.bs.tab', function() {
    window.location.hash = 'digests';
});
</script>
}
