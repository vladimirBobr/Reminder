@{
    ViewData["Title"] = "Админка";
}

<link rel="stylesheet" href="~/css/admin.css" />

<ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="notes-tab" data-bs-toggle="tab" data-bs-target="#notes-tab-pane" type="button" role="tab" data-tab="notes" style="font-weight: 600;">
            ...
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="events-tab" data-bs-toggle="tab" data-bs-target="#events-tab-pane" type="button" role="tab" data-tab="events">
            📅 Events
        </button>
    </li>
</ul>

<div class="tab-content" id="adminTabsContent">
    <!-- Tab 1: Заметки (существующий контент) -->
    <div class="tab-pane fade show active" id="notes-tab-pane" role="tabpanel" aria-labelledby="notes-tab">
        
    <div class="row g-2 px-1">
        @await Html.PartialAsync("Features/Workouts/Workouts")
        @await Html.PartialAsync("Features/Shopping/Shopping")
        @await Html.PartialAsync("Features/Digests/Digests")

        <div class="col-12 text-end">
            <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-secondary">Выйти</a>
        </div>
    </div>

    </div>

    <!-- Tab 2: События -->
    @await Html.PartialAsync("Features/Events/Events")
</div>

@section Scripts {
<script>
    // Consolidated API URLs
    window.apiUrls = {
        events: {
            getEvents: '@Url.Action("GetEvents", "Api")',
            addEvent: '@Url.Action("AddEvent", "Api")',
            updateEvent: '@Url.Action("UpdateEvent", "Api")',
            deleteEvent: '@Url.Action("DeleteEvent", "Api")'
        },
        workouts: {
            parseWorkouts: '@Url.Action("ParseWorkouts", "Api")',
            addWorkouts: '@Url.Action("AddWorkouts", "Api")'
        },
        shopping: {
            addShoppingItem: '@Url.Action("AddShoppingItem", "Api")'
        }
    };
</script>
<script src="~/js/admin/shared/shared.js"></script>
<script src="~/js/admin/features/events/events.js"></script>
<script src="~/js/admin/features/workouts/workouts.js"></script>
<script src="~/js/admin/features/shopping/shopping.js"></script>
<script src="~/js/admin/features/digests/digests.js"></script>
<script>
var eventsLoaded = false;

// Restore tab from URL hash
function restoreTabFromUrl() {
    var hash = window.location.hash.replace('#', '');
    if (hash === 'events') {
        // Manually switch tabs - Bootstrap CSS classes
        document.getElementById('notes-tab-pane').classList.remove('show', 'active');
        document.getElementById('notes-tab').classList.remove('active');
        document.getElementById('events-tab-pane').classList.add('show', 'active');
        document.getElementById('events-tab').classList.add('active');
        
        if (!eventsLoaded) {
            loadEvents();
            eventsLoaded = true;
        }
    }
}

// Restore tab on page load
restoreTabFromUrl();

document.getElementById('events-tab').addEventListener('shown.bs.tab', function() {
    if (!eventsLoaded) {
        loadEvents();
        eventsLoaded = true;
    }
    window.location.hash = 'events';
});

document.getElementById('notes-tab').addEventListener('shown.bs.tab', function() {
    window.location.hash = 'notes';
});

</script>
}
