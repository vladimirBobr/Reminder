@{
    ViewData["Title"] = "Админка";
}

<ul class="nav nav-tabs mb-3" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="notes-tab" data-bs-toggle="tab" data-bs-target="#notes-tab-pane" type="button" role="tab" data-tab="notes">
            📝 Заметки
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="events-tab" data-bs-toggle="tab" data-bs-target="#events-tab-pane" type="button" role="tab" data-tab="events">
            📋 События
        </button>
    </li>
</ul>

<div class="tab-content" id="adminTabsContent">
    <!-- Tab 1: Заметки (существующий контент) -->
    <div class="tab-pane fade show active" id="notes-tab-pane" role="tabpanel" aria-labelledby="notes-tab">
        
    <div class="row g-2 px-1">
        <!-- Add Note -->
        <div class="col-12">
            <div class="card">
                <div class="card-header text-white" style="background-color: rgba(0, 57, 166, 0.4);">
                    <h5 class="mb-0">📝 События</h5>
                </div>
                <div class="card-body">
                    <form id="noteForm">
                        <div class="row g-2 mb-3">
                            <div class="col-12 col-md-6">
                                <textarea name="note" class="form-control form-control-lg"
                                       placeholder="Текст" required rows="2"></textarea>
                            </div>
                            <div class="col-8 col-md-4">
                                <div class="input-group">
                                    <span id="dayOfWeek" class="input-group-text" style="width: 2.5rem; justify-content: center; font-weight: bold; background-color: inherit;"></span>
                                    <input type="date" id="noteDate" class="form-control form-control-lg" />
                                </div>
                                <input type="hidden" name="date" id="noteDateHidden" />
                            </div>
                            <div class="col-4 col-md-2">
                                <button type="submit" form="noteForm" class="btn btn-lg btn-secondary w-100">+</button>
                            </div>
                        </div>
                        
                        @* Date picker buttons *@
                        @{
                            var today = DateTime.Today;
                            var dayOfWeek = (int)today.DayOfWeek;
                            var monday = today.AddDays(-(dayOfWeek == 0 ? 6 : dayOfWeek - 1));
                            
                            string[] weekHeaders = { "Эта неделя", "+1 неделя", "+2 недели", "+3 недели" };
                        }
                        
                        @for (int week = 0; week < 4; week++)
                        {
                            var weekStart = monday.AddDays(week * 7);
                            <div class="mb-2">
                                <small class="text-muted fw-bold">@weekHeaders[week] (@weekStart.ToString("dd.MM") - @weekStart.AddDays(6).ToString("dd.MM")):</small>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    @for (int day = 0; day < 7; day++)
                                    {
                                        var date = weekStart.AddDays(day);
                                        var dateStr = date.ToString("yyyy-MM-dd");
                                        var dayLabel = date.ToString("ddd dd");
                                        var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
                                        var isPast = date < today;
                                        var isToday = date == today;
                                        
                                        string btnClass = "btn btn-sm ";
                                        if (isPast)
                                        {
                                            btnClass += "btn-outline-secondary disabled";
                                        }
                                        else if (isToday)
                                        {
                                            btnClass += "btn-warning text-dark";
                                        }
                                        else if (date.DayOfWeek == DayOfWeek.Saturday)
                                        {
                                            btnClass += "btn-outline-warning";
                                        }
                                        else if (date.DayOfWeek == DayOfWeek.Sunday)
                                        {
                                            btnClass += "btn-outline-danger";
                                        }
                                        else
                                        {
                                            btnClass += "btn-outline-primary";
                                        }
                                        
                                        var extraClass = "";
                                        
                                        <button type="button" class="@btnClass @extraClass date-btn" style="padding: 0.15rem 0.35rem; font-size: 0.9rem; min-width: 2.5rem;"
                                                @(isToday ? "data-is-today=\"true\"" : "")
                                                @(isPast ? "disabled" : "")
                                                onclick="@(isPast ? "" : $"setNoteDate('{dateStr}')")">@dayLabel</button>
                                    }
                                </div>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>

        <!-- Add Shopping Item -->
        <div class="col-12">
            <div class="card">
                <div class="card-header text-white" style="background-color: rgba(0, 100, 0, 0.4);">
                    <h5 class="mb-0">Что купить-то??</h5>
                </div>
                <div class="card-body">
                    <form id="shoppingForm">
                        <div class="row g-2">
                            <div class="col-8 col-md-10">
                                <input type="text" name="item" class="form-control form-control-lg"
                                       placeholder="Название товара" required />
                            </div>
                            <div class="col-4 col-md-2">
                                <button type="submit" form="shoppingForm" class="btn btn-lg btn-secondary w-100">+</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Send Digests -->
        <div class="col-12">
            <div class="card">
                <div class="card-header text-white" style="background-color: rgba(213, 43, 30, 0.5);">
                    <h5 class="mb-0">📬 Рассылка</h5>
                </div>
                <div class="card-body d-grid gap-3">
                    <button type="button" class="btn btn-lg btn-outline-secondary digest-btn" data-action="@Url.Action("Today", "Api")">
                        Отправить на сегодня
                    </button>
                    <button type="button" class="btn btn-lg btn-outline-secondary digest-btn" data-action="@Url.Action("Week", "Api")">
                        Отправить на неделю
                    </button>
                    <button type="button" class="btn btn-lg btn-outline-secondary digest-btn" data-action="@Url.Action("TwoWeek", "Api")">
                        Отправить на две недели
                    </button>
                </div>
            </div>
        </div>

        <div class="col-12 text-end">
            <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-secondary">Выйти</a>
        </div>
    </div>

    </div>

    <!-- Tab 2: События -->
    <div class="tab-pane fade" id="events-tab-pane" role="tabpanel" aria-labelledby="events-tab">
        <div class="card">
            <div class="card-header text-white" style="background-color: rgba(0, 57, 166, 0.4);">
                <h5 class="mb-0">📋 События</h5>
            </div>
            <div class="card-body p-0">
                <div id="eventsList" class="list-group list-group-flush">
                    <div class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        Загрузка событий...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// On page load, set today as selected
var daysRu = ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб'];

function updateDayOfWeek(dateStr) {
    var date = new Date(dateStr);
    var dayName = daysRu[date.getDay()];
    var el = document.getElementById('dayOfWeek');
    el.innerText = dayName;
    // Reset colors first
    el.classList.remove('text-warning', 'text-danger');
    el.style.color = '';
    // Set color for weekends
    if (date.getDay() === 6) {
        el.classList.add('text-warning');
    } else if (date.getDay() === 0) {
        el.classList.add('text-danger');
    }
}

document.addEventListener('DOMContentLoaded', function() {
    var today = new Date().toISOString().split('T')[0];
    document.getElementById('noteDate').value = today;
    updateDayOfWeek(today);
    // Find today button and mark it as selected
    document.querySelectorAll('.date-btn').forEach(function(btn) {
        if (btn.hasAttribute('data-is-today')) {
            btn.classList.remove('btn-warning', 'btn-outline-primary', 'text-dark');
            btn.classList.add('btn-primary');
        }
    });
});

function setNoteDate(dateStr) {
    document.getElementById('noteDate').value = dateStr;
    updateDayOfWeek(dateStr);
    // Restore all buttons to default state
    document.querySelectorAll('.date-btn').forEach(function(btn) {
        btn.classList.remove('btn-primary');
        if (btn.hasAttribute('data-is-today')) {
            btn.classList.add('btn-warning', 'text-dark');
        } else if (btn.classList.contains('btn-outline-warning') || btn.classList.contains('btn-outline-danger')) {
            // keep weekend colors
        } else {
            btn.classList.add('btn-outline-primary');
        }
    });
    // Mark clicked button as selected
    event.target.classList.remove('btn-warning', 'btn-outline-primary', 'text-dark');
    event.target.classList.add('btn-primary');
}

document.getElementById('noteDate').addEventListener('change', function(e) {
    updateDayOfWeek(e.target.value);
});

document.getElementById('noteForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var dateInput = document.getElementById('noteDate');
    var hiddenInput = document.getElementById('noteDateHidden');
    var noteText = document.querySelector('textarea[name="note"]').value;
    var dateValue = dateInput.value;
    if (dateValue) {
        var date = new Date(dateValue);
        var day = String(date.getDate()).padStart(2, '0');
        var month = String(date.getMonth() + 1).padStart(2, '0');
        var year = date.getFullYear();
        hiddenInput.value = day + '.' + month + '.' + year;
    }
    var formData = new FormData();
    formData.append('note', noteText);
    formData.append('date', hiddenInput.value);
    fetch('@Url.Action("AddNote", "Api")', {
        method: 'POST',
        body: formData
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            showToast(data.message, 'success', e.target.querySelector('button[type="submit"]'));
            document.querySelector('textarea[name="note"]').value = '';
        } else {
            showToast(data.message, 'error', e.target.querySelector('button[type="submit"]'));
        }
    })
    .catch(function(err) { showToast('Error: ' + err, 'error', e.target.querySelector('button[type="submit"]')); });
});

document.getElementById('shoppingForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var formData = new FormData(e.target);
    fetch('@Url.Action("AddShoppingItem", "Api")', {
        method: 'POST',
        body: formData
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            showToast(data.message, 'success', e.target.querySelector('button[type="submit"]'));
            e.target.reset();
        } else {
            showToast(data.message, 'error', e.target.querySelector('button[type="submit"]'));
        }
    })
    .catch(function(err) { showToast('Error: ' + err, 'error', e.target.querySelector('button[type="submit"]')); });
});

function showToast(message, type, anchorElement) {
    var toast = document.createElement('div');
    toast.className = 'toast-message toast-' + type;
    toast.textContent = message;
    
    if (anchorElement) {
        var rect = anchorElement.getBoundingClientRect();
        toast.style.position = 'fixed';
        toast.style.top = (rect.top - 10) + 'px';
        toast.style.right = (window.innerWidth - rect.right - 10) + 'px';
        toast.style.left = 'auto';
        toast.style.bottom = 'auto';
    }
    
    document.body.appendChild(toast);
    setTimeout(function() { toast.classList.add('show'); }, 10);
    setTimeout(function() {
        toast.classList.remove('show');
        setTimeout(function() { toast.remove(); }, 300);
    }, 3000);
}

// ==================== Events Tab Logic ====================

var eventsData = [];
var eventsLoaded = false;

// Restore tab from URL hash
function restoreTabFromUrl() {
    var hash = window.location.hash.replace('#', '');
    if (hash === 'events') {
        // Manually switch tabs - Bootstrap CSS classes
        document.getElementById('notes-tab-pane').classList.remove('show', 'active');
        document.getElementById('notes-tab').classList.remove('active');
        document.getElementById('events-tab-pane').classList.add('show', 'active');
        document.getElementById('events-tab').classList.add('active');
        
        if (!eventsLoaded) {
            loadEvents();
            eventsLoaded = true;
        }
    }
}

// Restore tab on page load
restoreTabFromUrl();

document.getElementById('events-tab').addEventListener('shown.bs.tab', function() {
    if (!eventsLoaded) {
        loadEvents();
        eventsLoaded = true;
    }
    window.location.hash = 'events';
});

document.getElementById('notes-tab').addEventListener('shown.bs.tab', function() {
    window.location.hash = 'notes';
});

function loadEvents() {
    var eventsList = document.getElementById('eventsList');
    eventsList.innerHTML = '<div class="text-center text-muted py-4"><div class="spinner-border spinner-border-sm" role="status"></div> Загрузка событий...</div>';
    
    fetch('@Url.Action("GetEvents", "Api")')
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                eventsData = data.events;
                renderEventsList();
            } else {
                eventsList.innerHTML = '<div class="text-danger p-3">Ошибка: ' + data.message + '</div>';
            }
        })
        .catch(function(err) {
            eventsList.innerHTML = '<div class="text-danger p-3">Ошибка загрузки: ' + err + '</div>';
        });
}

function renderEventsList() {
    var eventsList = document.getElementById('eventsList');
    if (eventsData.length === 0) {
        eventsList.innerHTML = '<div class="text-muted p-3">Нет событий</div>';
        return;
    }
    
    // Group events by date
    var groupedByDate = {};
    eventsData.forEach(function(event) {
        if (!groupedByDate[event.date]) groupedByDate[event.date] = [];
        groupedByDate[event.date].push(event);
    });
    
    // Sort dates
    var sortedDates = Object.keys(groupedByDate).sort();
    
    var html = '';
    
    sortedDates.forEach(function(dateStr) {
        var eventsOnDate = groupedByDate[dateStr];
        
        // Sort events by time (events without time go last)
        eventsOnDate.sort(function(a, b) {
            if (!a.time && !b.time) return 0;
            if (!a.time) return 1;
            if (!b.time) return -1;
            return a.time.localeCompare(b.time);
        });
        
        var firstEvent = eventsOnDate[0];
        var date = new Date(firstEvent.date);
        var dayName = daysRu[date.getDay()];
        var day = String(date.getDate()).padStart(2, '0');
        var month = String(date.getMonth() + 1).padStart(2, '0');
        var dateFormatted = day + '.' + month;
        var isWeekend = date.getDay() === 6 || date.getDay() === 0;
        var isSaturday = date.getDay() === 6;
        
        // Date header - smaller and colored by weekend
        var headerBgStyle = 'background-color: rgba(0, 57, 166, 0.08);';
        if (isSaturday) headerBgStyle = 'background-color: rgba(255, 193, 7, 0.15);'; // Warning yellow tint
        else if (isWeekend) headerBgStyle = 'background-color: rgba(220, 53, 69, 0.12);'; // Danger red tint
        html += '<div class="date-group-header px-3 py-1" style="' + headerBgStyle + ' border-bottom: 1px solid rgba(0, 57, 166, 0.1); font-size: 0.9rem;">';
        html += '<span class="fw-bold">' + dateFormatted + '</span>';
        html += ' <span class="text-muted">' + dayName + '</span>';
        if (eventsOnDate.length > 1) {
            html += ' <span class="badge bg-secondary ms-1" style="font-size: 0.75rem;">' + eventsOnDate.length + '</span>';
        }
        html += '</div>';
        
        // Events under this date
        eventsOnDate.forEach(function(event) {
            var subjectText = event.subject || event.description || 'Без названия';
            var textContent = subjectText;
            if (event.subject && event.description) {
                textContent = '<div>' + event.subject + '</div><div class="text-muted small" style="word-break: break-word;">' + event.description + '</div>';
            }
            
            html += '<div class="d-flex align-items-start gap-2 py-2 px-3 border-bottom event-item">';
            
            // Time (only if has Subject, not for description-only events)
            if (event.time && event.subject) {
                html += '<div class="flex-shrink-0 text-muted" style="min-width: 45px; font-size: 0.9rem;">' + event.time + '</div>';
            } else {
                html += '<div class="flex-shrink-0" style="min-width: 45px;"></div>';
            }
            
            // Event text
            html += '<div class="flex-grow-1 event-text" style="word-break: break-word; line-height: 1.4; white-space: pre-line;">' + textContent + '</div>';
            
            // Three-dot menu button
            html += '<div class="flex-shrink-0">';
            html += '<div class="dropdown">';
            html += '<button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" onclick="event.stopPropagation()">';
            html += '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">';
            html += '<circle cx="8" cy="3" r="1.5"/><circle cx="8" cy="8" r="1.5"/><circle cx="8" cy="13" r="1.5"/>';
            html += '</svg>';
            html += '</button>';
            html += '<div class="dropdown-menu dropdown-menu-end p-2 mobile-edit-menu" style="min-width: 280px;">';
            html += '<div class="mb-2">';
            html += '<label class="form-label small text-muted">Изменить дату</label>';
            html += '<input type="date" class="form-control form-control-sm" id="date-' + event.key + '" value="' + event.date + '" onchange="saveEventDate(\'' + event.key + '\', this.value)">';
            html += '</div>';
            html += '<hr class="my-2">';
            html += '<div class="mb-2">';
            html += '<label class="form-label small text-muted">Название</label>';
            html += '<input type="text" class="form-control form-control-sm" id="editSubject-' + event.key + '" value="' + (event.subject || '') + '">';
            html += '</div>';
            html += '<div class="mb-2">';
            html += '<label class="form-label small text-muted">Описание</label>';
            html += '<textarea class="form-control" rows="4" id="editDesc-' + event.key + '">' + (event.description || '') + '</textarea>';
            html += '</div>';
            html += '<div class="d-flex gap-2">';
            html += '<button class="btn btn-sm btn-primary flex-grow-1" onclick="saveEventEdit(\'' + event.key + '\')">Сохранить</button>';
            html += '<button class="btn btn-sm btn-outline-danger" onclick="deleteEvent(\'' + event.key + '\')">🗑️</button>';
            html += '</div>';
            html += '</div>';
            html += '</div>';
            html += '</div>';
            
            html += '</div>';
        });
    });
    
    eventsList.innerHTML = html;
}

// Context menu for editing
var editMenu = null;

function showEditMenu(e, key) {
    e.preventDefault();
    
    var event = eventsData.find(function(ev) { return ev.key === key; });
    if (!event) return;
    
    // Remove existing menu
    var existing = document.getElementById('editMenu');
    if (existing) existing.remove();
    
    // Create menu
    var menu = document.createElement('div');
    menu.id = 'editMenu';
    menu.className = 'dropdown-menu show p-3';
    menu.style.position = 'fixed';
    menu.style.left = Math.min(e.clientX, window.innerWidth - 200) + 'px';
    menu.style.top = Math.min(e.clientY, window.innerHeight - 150) + 'px';
    menu.style.minWidth = '200px';
    menu.style.zIndex = '9999';
    
    menu.innerHTML = '<div class="mb-2"><label class="form-label small text-muted">Название</label><input type="text" class="form-control" id="editSubject" value="' + (event.subject || '') + '"></div>' +
                     '<div class="mb-2"><label class="form-label small text-muted">Описание</label><textarea class="form-control" rows="5" id="editDesc">' + (event.description || '') + '</textarea></div>' +
                     '<button class="btn btn-sm btn-primary w-100" onclick="saveEventEdit(\'' + key + '\')">Сохранить</button>';
    
    document.body.appendChild(menu);
    editMenu = menu;
    
    // Make menu wider
    menu.style.minWidth = '400px';
    
    // Close on click outside (but not on menu itself)
    setTimeout(function() {
        document.addEventListener('click', function handler(e) {
            if (!menu.contains(e.target)) {
                closeEditMenu();
                document.removeEventListener('click', handler);
            }
        });
    }, 10);
}

function closeEditMenu() {
    var menu = document.getElementById('editMenu');
    if (menu) menu.remove();
    editMenu = null;
}

function saveEventEdit(key) {
    var subject = document.getElementById('editSubject-' + key).value;
    var description = document.getElementById('editDesc-' + key).value;
    
    fetch('@Url.Action("UpdateEvent", "Api")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, subject: subject, description: description })
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            // Update local cache with new key if changed
            if (data.newKey) {
                var idx = eventsData.findIndex(function(e) { return e.key === key; });
                if (idx !== -1) {
                    eventsData[idx].key = data.newKey;
                }
            }
            // Update subject and description in cache
            var event = eventsData.find(function(e) { return e.key === (data.newKey || key); });
            if (event) {
                event.subject = subject;
                event.description = description;
            }
            renderEventsList();
            showToast('Сохранено', 'success');
        } else {
            showToast('Ошибка: ' + data.message, 'error');
        }
    })
    .catch(function(err) {
        showToast('Ошибка: ' + err, 'error');
    });
}

function deleteEvent(key) {
    fetch('@Url.Action("DeleteEvent", "Api")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key })
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            showToast('Событие удалено', 'success');
            eventsData = eventsData.filter(function(e) { return e.key !== key; });
            renderEventsList();
        } else {
            showToast('Ошибка: ' + data.message, 'error');
        }
    })
    .catch(function(err) {
        showToast('Ошибка: ' + err, 'error');
    });
}

function saveEventDate(key, newDate) {
    if (!newDate) return;
    
    fetch('@Url.Action("UpdateEventDate", "Api")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, newDate: newDate })
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            showToast('Дата сохранена', 'success');
            // Update local cache with new key
            if (data.newKey) {
                var idx = eventsData.findIndex(function(e) { return e.key === key; });
                if (idx !== -1) {
                    eventsData[idx].key = data.newKey;
                    eventsData[idx].date = newDate;
                }
            }
            renderEventsList();
        } else {
            showToast('Ошибка: ' + data.message, 'error');
        }
    })
    .catch(function(err) {
        showToast('Ошибка: ' + err, 'error');
    });
}

// ==================== Digest Buttons ====================

document.querySelectorAll('.digest-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var action = btn.getAttribute('data-action');
        fetch(action, { method: 'POST' })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    showToast(data.message, 'success', btn);
                } else {
                    showToast(data.message, 'error', btn);
                }
            })
            .catch(function(err) { showToast('Error: ' + err, 'error', btn); });
    });
});
</script>

<style>
.date-block:hover { opacity: 0.7; }
.toast-message {
    position: fixed;
    bottom: 20px;
    right: 20px;
    padding: 12px 24px;
    border-radius: 4px;
    font-size: 1rem;
    z-index: 9999;
    opacity: 0;
