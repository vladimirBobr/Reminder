@model AdminIndexViewModel

@{
    ViewData["Title"] = "Admin";
}

<div class="row">
    <div class="col-12 d-flex justify-content-between align-items-center mb-4">
        <h1>Reminder Admin</h1>
        @if (Model.IsLoggedIn)
        {
            <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-secondary">Logout</a>
        }
    </div>
</div>

@if (!Model.IsLoggedIn)
{
    <div class="card">
        <div class="card-body text-center">
            <h5 class="card-title">Please login to access admin features</h5>
            <a href="@Url.Action("Login", "Admin")" class="btn btn-primary btn-lg mt-3">Login</a>
            <p class="card-text text-muted mt-3">
                Token: <code class="bg-light px-2 py-1 rounded">@Model.AdminToken</code>
            </p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <!-- Send Digests -->
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📬 Send Digests</h5>
                </div>
                <div class="card-body d-grid gap-3">
                    <a href="@Url.Action("Today", "Api")" class="btn btn-lg btn-primary">
                        Send Today's Digest
                    </a>
                    <a href="@Url.Action("Week", "Api")" class="btn btn-lg btn-primary">
                        Send Weekly Digest
                    </a>
                    <a href="@Url.Action("TwoWeek", "Api")" class="btn btn-lg btn-primary">
                        Send Two Week Digest
                    </a>
                </div>
            </div>
        </div>

        <!-- Add Note -->
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">📝 Add Note</h5>
                </div>
                <div class="card-body">
                    <form method="get" action="@Url.Action("AddNote", "Api")" id="noteForm">
                        <div class="row g-2 mb-3">
                            <div class="col-12 col-md-6">
                                <input type="text" name="note" class="form-control form-control-lg"
                                       placeholder="Note text" required />
                            </div>
                            <div class="col-8 col-md-4">
                                <input type="date" id="noteDate" class="form-control form-control-lg" />
                                <input type="hidden" name="date" id="noteDateHidden" />
                            </div>
                            <div class="col-4 col-md-2">
                                <button type="submit" class="btn btn-lg btn-success w-100">Add</button>
                            </div>
                        </div>
                        
                        @* Date picker buttons *@
                        @{
                            var today = DateTime.Today;
                            var dayOfWeek = (int)today.DayOfWeek;
                            var monday = today.AddDays(-(dayOfWeek == 0 ? 6 : dayOfWeek - 1));
                            
                            string[] weekHeaders = { "This week", "+1 week", "+2 weeks", "+3 weeks" };
                        }
                        
                        @for (int week = 0; week < 4; week++)
                        {
                            var weekStart = monday.AddDays(week * 7);
                            <div class="mb-2">
                                <small class="text-muted fw-bold">@weekHeaders[week] (@weekStart.ToString("dd.MM") - @weekStart.AddDays(6).ToString("dd.MM")):</small>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    @for (int day = 0; day < 7; day++)
                                    {
                                        var date = weekStart.AddDays(day);
                                        var dateStr = date.ToString("yyyy-MM-dd");
                                        var dayLabel = date.ToString("ddd dd");
                                        var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
                                        var isPast = date < today;
                                        var isToday = date == today;
                                        
                                        string btnClass = "btn btn-sm ";
                                        if (isPast)
                                        {
                                            btnClass += "btn-outline-secondary disabled";
                                        }
                                        else if (isToday)
                                        {
                                            btnClass += "btn-warning text-dark";
                                        }
                                        else
                                        {
                                            btnClass += "btn-outline-primary";
                                        }
                                        
                                        // For weekends, add a left margin; for weekdays, no margin
                                        var extraClass = isWeekend ? "ms-3" : "";
                                        
                                        <button type="button" class="@btnClass @extraClass date-btn"
                                                @(isToday ? "data-is-today=\"true\"" : "")
                                                @(isPast ? "disabled" : "")
                                                onclick="@(isPast ? "" : $"setNoteDate('{dateStr}')")">@dayLabel</button>
                                    }
                                </div>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>

        <!-- Add Shopping Item -->
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">🛒 Add Shopping Item</h5>
                </div>
                <div class="card-body">
                    <form method="get" action="@Url.Action("AddShoppingItem", "Api")">
                        <div class="row g-2">
                            <div class="col-8 col-md-10">
                                <input type="text" name="item" class="form-control form-control-lg" 
                                       placeholder="Item name" required />
                            </div>
                            <div class="col-4 col-md-2">
                                <button type="submit" class="btn btn-lg btn-success w-100">Add</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@* Alerts in the end, so they don't shift the cards *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-4" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@section Scripts {
<script>
// On page load, set today as selected
document.addEventListener('DOMContentLoaded', function() {
    var today = new Date().toISOString().split('T')[0];
    document.getElementById('noteDate').value = today;
    // Find today button and mark it as selected
    document.querySelectorAll('.date-btn').forEach(function(btn) {
        if (btn.hasAttribute('data-is-today')) {
            btn.classList.remove('btn-warning', 'btn-outline-primary', 'text-dark');
            btn.classList.add('btn-primary');
        }
    });
});

function setNoteDate(dateStr) {
    document.getElementById('noteDate').value = dateStr;
    // Restore all buttons to default state
    document.querySelectorAll('.date-btn').forEach(function(btn) {
        btn.classList.remove('btn-primary');
        if (btn.hasAttribute('data-is-today')) {
            btn.classList.add('btn-warning', 'text-dark');
        } else {
            btn.classList.add('btn-outline-primary');
        }
    });
    // Mark clicked button as selected
    event.target.classList.remove('btn-warning', 'btn-outline-primary', 'text-dark');
    event.target.classList.add('btn-primary');
}

document.getElementById('noteForm').addEventListener('submit', function(e) {
    var dateInput = document.getElementById('noteDate');
    var hiddenInput = document.getElementById('noteDateHidden');
    if (dateInput.value) {
        var date = new Date(dateInput.value);
        var day = String(date.getDate()).padStart(2, '0');
        var month = String(date.getMonth() + 1).padStart(2, '0');
        var year = date.getFullYear();
        hiddenInput.value = day + '.' + month + '.' + year;
    }
});
</script>
}